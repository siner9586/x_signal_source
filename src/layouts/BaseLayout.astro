---
import '../styles/global.css';
import '../styles/longform.css';
const { title = 'Today’s Signal Source', description = '每日整理公开网络上的 AI、科技、产品、创业、投资和研究高信号内容。' } = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    <header class="nav">
      <div class="shell nav-inner">
        <a class="brand" href="/" aria-label="Today’s Signal Source home">
          <span class="brand-mark" aria-hidden="true"></span>
          <span class="brand-text">Today’s Signal Source</span>
          <span class="brand-status"><span class="status-dot" aria-hidden="true"></span>Live public signals</span>
        </a>
        <nav class="nav-links" aria-label="Primary">
          <a class="active" href="/">Today</a>
          <a href="/podcasts/">Podcast Signals</a>
          <a href="/transcripts/">Transcripts</a>
          <a href="/longform/">Longform</a>
          <a href="/topics/">Topics</a>
          <a href="/sources/">Sources</a>
          <a href="/about/">About</a>
          <a href="https://github.com/siner9586/x_signal_source" target="_blank" rel="noreferrer">GitHub</a>
          <div class="wechat-nav">
            <button class="wechat-trigger" type="button" aria-haspopup="dialog" aria-expanded="false">公众号</button>
            <div class="wechat-popover" role="dialog" aria-label="微信公众号二维码">
              <div class="wechat-card">
                <img src="/wechat-qrcode.svg" alt="微信公众号二维码" loading="lazy" />
                <strong>扫码关注公众号</strong>
                <span>每日高信号来源与复盘更新</span>
              </div>
            </div>
          </div>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="footer">
      <div class="shell">
        <p><strong>Today’s Signal Source</strong> · 使用公开来源、轻量索引与静态归档。Podcast Signals 作为私人长访谈逐字稿学习库扩展，支持本地开源 ASR、完整逐字稿、时间戳跳转与全文检索。</p>
      </div>
    </footer>
    <script is:inline>
      const wechat = document.querySelector('.wechat-nav');
      const trigger = document.querySelector('.wechat-trigger');
      trigger?.addEventListener('click', (event) => {
        event.stopPropagation();
        const open = wechat?.classList.toggle('open');
        trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
      document.addEventListener('click', (event) => {
        if (!wechat?.contains(event.target)) {
          wechat?.classList.remove('open');
          trigger?.setAttribute('aria-expanded', 'false');
        }
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          wechat?.classList.remove('open');
          trigger?.setAttribute('aria-expanded', 'false');
        }
      });
    </script>
  </body>
</html>
