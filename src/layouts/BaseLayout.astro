---
import '../styles/global.css';
const { title = 'X Signal Source', description = '每日整理公开网络上的 AI、科技、产品、创业、投资和研究高信号内容。' } = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <header class="nav">
      <div class="shell nav-inner">
        <a class="brand" href="/">
          <span class="brand-mark"></span>
          <span>X Signal Source</span>
        </a>
        <nav class="nav-links" aria-label="Primary">
          <a href="/issues/latest/">Latest</a>
          <a href="/issues/">Issues</a>
          <a href="/sources/">Sources</a>
          <a href="/topics/">Topics</a>
          <a href="/about/">About</a>
          <div class="wechat-nav">
            <button class="wechat-trigger" type="button" aria-haspopup="dialog" aria-expanded="false">公众号</button>
            <div class="wechat-popover" role="dialog" aria-label="微信公众号二维码">
              <div class="wechat-card">
                <img src="/wechat-qrcode.svg" alt="微信公众号二维码" loading="lazy" />
                <strong>扫码关注公众号</strong>
                <span>每日高信号来源与复盘更新</span>
              </div>
            </div>
          </div>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="footer">
      <div class="shell">
        <p><strong>X Signal Source</strong> · 使用公开来源、轻量索引与静态归档。每天北京时间 06:07 起自动更新，最多 50 次冗余补偿检查。</p>
      </div>
    </footer>
    <script is:inline>
      const wechat = document.querySelector('.wechat-nav');
      const trigger = document.querySelector('.wechat-trigger');
      trigger?.addEventListener('click', (event) => {
        event.stopPropagation();
        const open = wechat?.classList.toggle('open');
        trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
      document.addEventListener('click', (event) => {
        if (!wechat?.contains(event.target)) {
          wechat?.classList.remove('open');
          trigger?.setAttribute('aria-expanded', 'false');
        }
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          wechat?.classList.remove('open');
          trigger?.setAttribute('aria-expanded', 'false');
        }
      });
    </script>
  </body>
</html>
