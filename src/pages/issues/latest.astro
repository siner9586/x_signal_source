---
import fs from 'node:fs';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MetricStrip from '../../components/MetricStrip.astro';
import TodayReadout from '../../components/TodayReadout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import SignalCard from '../../components/SignalCard.astro';
const readJson = (p, fallback) => fs.existsSync(p) ? JSON.parse(fs.readFileSync(p, 'utf8')) : fallback;
const empty = { metadata:{issue_date:'pending',selected_count:0,candidates_count:0,sources_scanned:0,duplicates_blocked:0}, summary:{one_liner:'等待首次 daily 流水线生成。',trends:[],watch_next:[]}, must_read:[], worth_reading:[], signal_watch:[], hot_rank:[], clusters:[] };
const publicLatest = readJson('public/index-data/latest.json', empty);
const selectedPublic = [...(publicLatest.must_read||[]), ...(publicLatest.worth_reading||[]), ...(publicLatest.signal_watch||[])];
const issuesIndex = readJson('public/index-data/issues.json', []);
const fallbackDate = publicLatest.metadata?.issue_date || issuesIndex[0]?.date;
const frozenIssue = fallbackDate ? readJson(`data/issues/${fallbackDate}.json`, publicLatest) : publicLatest;
const latest = selectedPublic.length ? publicLatest : frozenIssue;
const metrics = [
  { label: '抓取源数量', value: latest.metadata.sources_scanned, primary: true },
  { label: '候选数量', value: latest.metadata.candidates_count },
  { label: '入选数量', value: latest.metadata.selected_count },
  { label: '去重数量', value: latest.metadata.duplicates_blocked },
  { label: '更新时间', value: latest.metadata.generated_at?.slice(0,10) || latest.metadata.issue_date, date: true }
];
---
<BaseLayout title={`Latest Issue | ${latest.metadata.issue_date} | Today’s Signal Source`}>
  <section class="hero hero--subpage shell">
    <div class="hero-panel">
      <span class="eyebrow">Latest Issue · {latest.metadata.issue_date}</span>
      <h1>最新一期高信号内容</h1>
      <p class="hero-lead">{latest.summary.one_liner}</p>
      <MetricStrip metrics={metrics} />
      <div class="tabs"><span class="tab active">综合排序</span><span class="tab">热度排序见下方</span><span class="tab">来源类型筛选：静态搜索支持</span></div>
    </div>
  </section>
  <TodayReadout latest={latest} />
  <section class="section shell section--featured">
    <SectionHeader title="Must Read" description="每条都保留原始链接和具体入选理由。" count={(latest.must_read || []).length} />
    <div class="grid grid--featured">{(latest.must_read || []).map((item, index) => <SignalCard item={item} variant="featured" rank={index + 1} />)}</div>
  </section>
  <section class="section shell">
    <SectionHeader title="Worth Reading" description="适合延伸阅读与后续复盘。" count={(latest.worth_reading || []).length} />
    <div class="grid grid--compact">{(latest.worth_reading || []).map((item, index) => <SignalCard item={item} variant="compact" rank={index + 1} />)}</div>
  </section>
  <section class="section shell section--watch">
    <SectionHeader title="Signal Watch" description="观察信号：不夸大，但保留追踪价值。" count={(latest.signal_watch || []).length} />
    <div class="grid grid--watch">{(latest.signal_watch || []).map((item, index) => <SignalCard item={item} variant="watch" rank={index + 1} />)}</div>
  </section>
  <section class="section shell">
    <SectionHeader title="热度排序 Top 20" description="热度只占总分 10%，不作为唯一入选依据。" />
    <div class="list">{(latest.hot_rank || []).map((item) => <div class="list-row"><div><strong>{item.title}</strong><div class="small">{item.source_domain} · heat {item.heat_score} · total {item.total_score}</div></div><a class="btn" href={item.canonical_url} target="_blank">打开</a></div>)}</div>
  </section>
  <section class="section shell">
    <SectionHeader title="Topic Clusters" description="同一事件多来源合并，避免同一期重复展示。" />
    <div class="list">{(latest.clusters || []).map((c) => <div class="list-row"><div><strong>{c.title}</strong><div class="small">{c.cluster_id} · score {c.score}</div></div><a class="btn" href={c.primary_source} target="_blank">Primary source</a></div>)}</div>
  </section>
</BaseLayout>
