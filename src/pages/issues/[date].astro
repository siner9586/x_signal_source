---
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MetricStrip from '../../components/MetricStrip.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import SignalCard from '../../components/SignalCard.astro';
export function getStaticPaths() {
  const dir = 'data/issues';
  if (!fs.existsSync(dir)) return [];
  return fs.readdirSync(dir).filter((f) => f.endsWith('.json')).map((file) => {
    const issue = JSON.parse(fs.readFileSync(path.join(dir, file), 'utf8'));
    return { params: { date: issue.metadata.issue_date }, props: { issue } };
  });
}
const { issue } = Astro.props;
const metrics = [
  { label: 'Sources', value: issue.metadata.sources_scanned, primary: true },
  { label: 'Candidates', value: issue.metadata.candidates_count },
  { label: 'Selected', value: issue.metadata.selected_count },
  { label: 'Duplicates', value: issue.metadata.duplicates_blocked },
  { label: 'Timezone', value: issue.metadata.timezone || 'BJT', date: true }
];
---
<BaseLayout title={`Issue ${issue.metadata.issue_date} | Today’s Signal Source`}>
  <section class="hero hero--subpage shell">
    <div class="hero-panel">
      <span class="eyebrow">Frozen Issue · {issue.metadata.issue_date}</span>
      <h1>{issue.metadata.issue_date}</h1>
      <p class="hero-lead">{issue.summary.one_liner}</p>
      <MetricStrip metrics={metrics} />
    </div>
  </section>
  <section class="section shell section--featured"><SectionHeader title="Must Read" count={issue.must_read.length} /><div class="grid grid--featured">{issue.must_read.map((item, index) => <SignalCard item={item} variant="featured" rank={index + 1} />)}</div></section>
  <section class="section shell"><SectionHeader title="Worth Reading" count={issue.worth_reading.length} /><div class="grid grid--compact">{issue.worth_reading.map((item, index) => <SignalCard item={item} variant="compact" rank={index + 1} />)}</div></section>
  <section class="section shell section--watch"><SectionHeader title="Signal Watch" count={issue.signal_watch.length} /><div class="grid grid--watch">{issue.signal_watch.map((item, index) => <SignalCard item={item} variant="watch" rank={index + 1} />)}</div></section>
</BaseLayout>
