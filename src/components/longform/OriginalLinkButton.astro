---
const { href = '', url: inputUrl = '', label = 'Watch original', seconds = null } = Astro.props;
const target = href || inputUrl;
const resolved = target && seconds !== null && target.includes('youtube') ? `${target}${target.includes('?') ? '&' : '?'}t=${Math.floor(seconds)}s` : target;
---
{target ? <a class="lf-btn primary" href={resolved} target="_blank" rel="noreferrer">{label}</a> : <span class="lf-btn">Original link pending</span>}
