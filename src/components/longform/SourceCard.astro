---
const { source } = Astro.props;
---
<article class="lf-card" data-source-card={`${source.name || ''} ${(source.tags || []).join(' ')} ${source.category || ''}`}>
  <span class="lf-pill">{source.source_type || 'source'} · {source.language || 'unknown'} · priority {source.priority || '-'}</span>
  <h3>{source.name}</h3>
  <p>{source.notes || 'Longform source tracked by Podcast Signals.'}</p>
  <div class="lf-meta">{(source.tags || []).slice(0, 6).map((tag) => <span class="lf-tag">{tag}</span>)}</div>
  <div class="lf-actions">
    {source.homepage_url && <a class="lf-btn" href={source.homepage_url} target="_blank" rel="noreferrer">Homepage</a>}
    {source.youtube_url && <a class="lf-btn" href={source.youtube_url} target="_blank" rel="noreferrer">YouTube</a>}
    {source.rss_url && <a class="lf-btn" href={source.rss_url} target="_blank" rel="noreferrer">RSS</a>}
    <span class="lf-tag">{source.discovery_status || 'tracked'}</span>
  </div>
</article>
