---
const { stats = {} } = Astro.props;
---
<div class="lf-grid">
  <div class="lf-card"><span class="lf-pill">Total words</span><h3>{stats.words || 0}</h3></div>
  <div class="lf-card"><span class="lf-pill">Total hours</span><h3>{stats.hours || 0}</h3></div>
  <div class="lf-card"><span class="lf-pill">Recent transcripts</span><h3>{stats.recent || 0}</h3></div>
</div>
