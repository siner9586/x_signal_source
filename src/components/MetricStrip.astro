---
const { metrics = [] } = Astro.props;
---
<div class="metric-strip" aria-label="Today signal metrics">
  {metrics.map((metric) => (
    <article class={`metric-card ${metric.primary ? 'metric-card--primary' : ''} ${metric.date ? 'metric-card--date' : ''}`}>
      <strong>{metric.value ?? '--'}</strong>
      <span>{metric.label}</span>
    </article>
  ))}
</div>
